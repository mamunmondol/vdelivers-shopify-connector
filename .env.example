# ─── Shopify App Credentials ─────────────────────────────────────────────────
# From Shopify Partner Dashboard → Your App → Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Scopes requested from merchants
SHOPIFY_SCOPES=read_orders,write_orders,read_products,write_products,read_customers,write_customers,read_inventory,write_inventory,read_fulfillments,write_fulfillments

# Public URL of THIS connector server (no trailing slash)
HOST_URL=https://connector.vdelivers.com

# ─── PostgreSQL Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vdelivers_shopify

# ─── Security ─────────────────────────────────────────────────────────────────
# Secret for signing OAuth state JWTs (min 32 chars, random)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Session secret for dashboard login
SESSION_SECRET=another-long-random-string-for-sessions

# ─── Dashboard Login ──────────────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# ─── vDelivers API (optional) ─────────────────────────────────────────────────
# If set, synced data is also pushed to your vDelivers backend
# Leave blank to only store in the connector's own database
VDELIVERS_API_URL=
VDELIVERS_API_KEY=

# ─── Sync Settings ────────────────────────────────────────────────────────────
# How often (minutes) to poll Shopify for missed webhooks
POLL_INTERVAL_MINUTES=5

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
